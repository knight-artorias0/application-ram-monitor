# Maintainer: application-ram-monitor contributors
pkgname=appmon
pkgver=0.1.0
pkgrel=1
pkgdesc="Terminal monitor that aggregates RAM and CPU usage per application"
arch=('any')
url="https://github.com/YOUR_USER/application-ram-monitor"
license=('MIT')
depends=('python' 'python-textual')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
